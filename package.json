{
  "name": "kmalumnos",
  "version": "1.3.6",
  "description": "Gestión de kilómetros de prácticas para autoescuela",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.kmalumnos.app",
    "productName": "KMAlumnos",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "db.js",
      "sync.js",
      "index.html",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "danixp3",
      "repo": "kmalumnos"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.3",
    "electron-updater": "^6.8.9",
    "ws": "^8.21.0"
  }
}
